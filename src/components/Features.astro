    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />`,
    title: "Webshop & Billing",
    description: "Customer-facing storefront with real-time domain search, multi-step checkout with TLD-specific flows, Stripe payments, and full billing system — invoicing, subscriptions, tax rules, promotions, partner commissions, and electronic vetting."
  },
];
---

<section id="features" class="relative py-24 border-t border-gray-800/50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Everything you need to host</h2>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto">
        A complete hosting platform with every infrastructure primitive, all accessible via a unified API.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {features.map((feature) => {
        const Tag = feature.link ? 'a' : 'div';
        const linkProps = feature.link ? { href: feature.link, target: '_blank', rel: 'noopener noreferrer' } : {};
        return (
          <Tag {...linkProps} class="group rounded-2xl border border-gray-800 bg-surface-2 p-6 hover:border-brand-500/30 hover:bg-surface-3 transition-all duration-300">
            <div class="h-10 w-10 rounded-xl bg-brand-500/10 flex items-center justify-center mb-4 group-hover:bg-brand-500/20 transition-colors">
              <svg class="h-5 w-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <Fragment set:html={feature.icon} />
              </svg>
            </div>
            <h3 class="font-semibold text-white mb-2">
              {feature.title}
              {feature.link && (
                <svg class="inline-block h-3.5 w-3.5 ml-1.5 text-gray-500 group-hover:text-brand-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
              )}
            </h3>
            <p class="text-sm text-gray-400 leading-relaxed">{feature.description}</p>
          </Tag>
        );
      })}
    </div>
  </div>
</section>
