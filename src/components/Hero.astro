---
---

<section class="relative overflow-hidden">
  <!-- Gradient background -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--color-brand-900)_0%,_var(--color-surface)_70%)]"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-brand-500/10 blur-[120px] rounded-full"></div>

  <!-- Grid overlay -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(99,102,241,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(99,102,241,0.03)_1px,transparent_1px)] bg-[size:64px_64px]"></div>

  <nav class="relative z-10 max-w-6xl mx-auto px-6 py-6 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="h-8 w-8 rounded-lg bg-brand-500 flex items-center justify-center">
        <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" />
        </svg>
      </div>
      <span class="text-lg font-bold text-white">Massive Hosting</span>
    </div>
    <div class="flex items-center gap-6">
      <a href="#features" class="text-sm text-gray-400 hover:text-white transition-colors">Features</a>
      <a href="#terraform" class="text-sm text-gray-400 hover:text-white transition-colors">Terraform</a>
      <a href="#resources" class="text-sm text-gray-400 hover:text-white transition-colors">Resources</a>
      <a href="https://github.com/Massive-Hosting" class="text-sm text-gray-400 hover:text-white transition-colors flex items-center gap-1.5">
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>
  </nav>

  <div class="relative z-10 max-w-6xl mx-auto px-6 pt-24 pb-32 text-center">
    <div class="inline-flex items-center gap-2 rounded-full border border-brand-500/20 bg-brand-500/5 px-4 py-1.5 text-sm text-brand-300 mb-8">
      <span class="h-1.5 w-1.5 rounded-full bg-brand-400 animate-pulse"></span>
      Research Project
    </div>

    <h1 class="text-5xl sm:text-7xl font-black tracking-tight text-white leading-[1.1] mb-6">
      Modern Hosting,
      <br />
      <span class="bg-gradient-to-r from-brand-400 to-brand-600 bg-clip-text text-transparent">From Scratch</span>
    </h1>

    <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-12 leading-relaxed">
      A research platform exploring how modern mass hosting should work. Multi-tenant isolation, automated provisioning, and a complete API — with a Terraform provider on top.
    </p>

    <div class="flex items-center justify-center gap-4">
      <a href="#terraform" class="group inline-flex items-center gap-2 rounded-xl bg-brand-600 px-6 py-3 text-sm font-semibold text-white hover:bg-brand-500 transition-all shadow-lg shadow-brand-500/25 hover:shadow-brand-500/40">
        Explore the Terraform Provider
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
      </a>
      <a href="https://github.com/Massive-Hosting/terraform-provider-hosting" class="inline-flex items-center gap-2 rounded-xl border border-gray-700 bg-surface-2 px-6 py-3 text-sm font-semibold text-gray-300 hover:border-gray-600 hover:text-white transition-all">
        View on GitHub
      </a>
    </div>

    <!-- Terminal preview -->
    <div class="mt-16 max-w-2xl mx-auto">
      <div class="rounded-2xl border border-gray-800 bg-surface-2 shadow-2xl overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-gray-800">
          <div class="h-3 w-3 rounded-full bg-red-500/80"></div>
          <div class="h-3 w-3 rounded-full bg-yellow-500/80"></div>
          <div class="h-3 w-3 rounded-full bg-green-500/80"></div>
          <span class="ml-2 text-xs text-gray-500 font-mono">terminal</span>
        </div>
        <div class="p-6 font-mono text-sm leading-relaxed">
          <p class="text-gray-500">$ terraform init</p>
          <p class="text-gray-400 mt-1">Initializing provider plugins...</p>
          <p class="text-gray-400">- Installing <span class="text-brand-400">massive-hosting/hosting</span> v0.2.0...</p>
          <p class="text-gray-400">- Installed massive-hosting/hosting v0.2.0</p>
          <p class="text-green-400 mt-2">Terraform has been successfully initialized!</p>
          <p class="mt-3 text-gray-500">$ terraform apply</p>
          <p class="text-gray-400 mt-1">hosting_webapp.myapp: Creating...</p>
          <p class="text-gray-400">hosting_database.mydb: Creating...</p>
          <p class="text-gray-400">hosting_fqdn.main: Creating...</p>
          <p class="text-green-400 mt-1">Apply complete! Resources: 3 added, 0 changed, 0 destroyed.</p>
        </div>
      </div>
    </div>
  </div>
</section>
